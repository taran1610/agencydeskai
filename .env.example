# Public site URL (no trailing slash) — required for X/Twitter cards & sitemap
VITE_SITE_URL=https://agencydesk.ai

# Your X handle without @ (shows footer link + twitter:site meta)
VITE_X_HANDLE=agencydeskai

# Contact email in footer
VITE_CONTACT_EMAIL=liber1821@gmail.com

# Optional: Plausible analytics (domain only, e.g. agencydesk.ai)
VITE_PLAUSIBLE_DOMAIN=

# Operations console URL (platform app — sign in / dashboard)
# Local dev: http://localhost:3000
# Production default: https://agencydeskai-app.vercel.app
VITE_APP_URL=http://localhost:3000

# Supabase — waitlist signups (see docs/supabase-setup.md)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
